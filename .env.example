# ──────────────────────────────────────────────────────────────────
# SentimentIQ Environment Configuration
# Copy this file to .env and update values for your environment
# ──────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# JWT algorithm for token signing
ALGORITHM=HS256

# Access token expiration time in minutes (default: 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./sentimentiq.db

# PostgreSQL (production recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/sentimentiq

# MySQL:
# DATABASE_URL=mysql://username:password@localhost:3306/sentimentiq

# ── Application ───────────────────────────────────────────────────
# Set to 'development' or 'production'
# ENVIRONMENT=development

# ── Logging ────────────────────────────────────────────────────────
# Set to 'DEBUG', 'INFO', 'WARNING', 'ERROR'
# LOG_LEVEL=INFO
